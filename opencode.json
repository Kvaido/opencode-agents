{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "init_files": [
    "AGENTS.md",
    "DECISIONS.md",
    "RUN_CONTEXT.md"
  ],
  "agent": {
    "orchestrator": {
      "description": "Main coordinator of the agent team",
      "mode": "primary",
      "model": "opencode-go/minimax-m2.5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "planner": {
      "description": "Creates detailed, incremental implementation plans",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "tools": {
        "write": true,
        "edit": false,
        "bash": false
      }
    },
    "architect": {
      "description": "Evaluates architecture impact and module boundaries",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "tools": {
        "write": true,
        "edit": false,
        "bash": false
      }
    },
    "coder": {
      "description": "Implements features, fixes and refactors code",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "reviewer": {
      "description": "Performs strict code review",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "tester": {
      "description": "Writes and fixes unit/integration tests",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "security": {
      "description": "Scans for security vulnerabilities",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "docs": {
      "description": "Creates and maintains documentation",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "tools": {
        "write": true,
        "edit": true,
        "bash": false
      }
    }
  }
}
